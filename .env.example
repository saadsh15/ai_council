# THE COUNCIL - Environment Configuration Example
# Copy this file to .env and fill in your API keys

# --- Local AI Models (Ollama) ---
# Default Ollama endpoint (change if not running locally)
OLLAMA_BASE_URL=http://localhost:11434

# --- Web AI Providers ---

# Google Gemini API Key
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek API Key
# Get it from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Anthropic Claude API Key (Future Support)
# Get it from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_claude_api_key_here

# OpenAI API Key (Future Support)
# Get it from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# --- Optional Configurations ---
# LOG_LEVEL=INFO
# CONSENSUS_THRESHOLD=80
